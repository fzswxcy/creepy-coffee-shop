{
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "lib": ["dom", "es2015", "es2016", "es2017"],
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "outDir": "./temp",
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["assets/scripts/*"]
    }
  },
  "include": [
    "assets/scripts/**/*",
    "config/**/*"
  ],
  "exclude": [
    "node_modules",
    "temp",
    "build"
  ]
}